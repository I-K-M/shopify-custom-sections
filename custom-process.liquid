{% comment %}
  Section: Process steps with arrows
  - Background image + overlay (from custom-highlights template)
  - Pretitle (icon + text)
  - Heading + intro + bottom note
  - Steps row: step cards with arrow circles between
{% endcomment %}

{% assign sid = section.id | replace: '_', '' | downcase %}

{% style %}
.process-steps-{{ sid }}{
  position: relative;
  overflow: hidden;
  padding-top: {{ section.settings.section_padding_top }}px;
  padding-bottom: {{ section.settings.section_padding_bottom }}px;
  margin-top: {{ section.settings.section_margin_top }}px;
  margin-bottom: {{ section.settings.section_margin_bottom }}px;
  color: {{ section.settings.text_color }};
}
.process-steps__bg-{{ sid }}{
  position: absolute;
  inset: 0;
  z-index: 0;
}
.process-steps__bg-img-{{ sid }}{
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.process-steps__overlay-{{ sid }}{
  position: absolute;
  inset: 0;
  background: {{ section.settings.overlay_color }};
  opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
}

.process-steps__wrap-{{ sid }}{
  position: relative;
  z-index: 1;
  text-align: center;
}

.process-steps__header-{{ sid }}{
  max-width: {{ section.settings.header_max_width }}px;
  margin: 0 auto {{ section.settings.header_gap }}px auto;
}

.process-steps__heading-{{ sid }}{
  margin: 0;
  font-size: {{ section.settings.heading_size }}px;
  line-height: 1.1;
  color: {{ section.settings.heading_color }} !important;
}

.process-steps__text-{{ sid }}{
  margin-top: 14px;
  font-size: {{ section.settings.body_size }}px;
  line-height: 1.5;
}
.process-steps__text-{{ sid }} p{ margin: 0; }

.process-steps__note-{{ sid }}{
  margin: {{ section.settings.note_gap }}px auto 0 auto;
  max-width: {{ section.settings.note_max_width }}px;
  font-size: {{ section.settings.note_size }}px;
  line-height: 1.55;
  color: {{ section.settings.note_color }};
}
.process-steps__note-{{ sid }} p{ margin: 0; }

.process-steps__strip-{{ sid }}{
  max-width: {{ section.settings.strip_max_width }}px;
  margin: 0 auto;
  background: {{ section.settings.strip_bg }};
  border-radius: {{ section.settings.strip_radius }}px;
  overflow: hidden;
  box-shadow: 0 10px 25px rgba(0,0,0,0.18);
}

.process-steps__grid-{{ sid }}{
  display: grid;
  grid-template-columns: repeat({{ section.blocks.size | default: 4 }}, 1fr);
  position: relative;
}

.process-steps__step-{{ sid }}{
  position: relative;
  padding: {{ section.settings.step_padding_y }}px {{ section.settings.step_padding_x }}px;
  min-height: {{ section.settings.step_min_height }}px;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-shadow: 10px 0 10px #00000020;
}
.process-steps__step-{{ sid }}:not(:first-child){
  border-left: 1px solid {{ section.settings.step_divider_color }};
}

.process-steps__step-text-{{ sid }}{
  font-size: {{ section.settings.step_text_size }}px;
  line-height: 1.25;
  color: {{ section.settings.step_text_color }};
  font-weight: 600;
  max-width: 240px;
}

.process-steps__arrow-{{ sid }}{
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  width: {{ section.settings.arrow_size }}px;
  height: {{ section.settings.arrow_size }}px;
  border-radius: 999px;
  background: {{ section.settings.arrow_bg }};
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 18px rgba(0,0,0,0.18);
}
.process-steps__arrow-{{ sid }} svg{
  width: calc({{ section.settings.arrow_size }}px * 0.46);
  height: calc({{ section.settings.arrow_size }}px * 0.46);
  display: block;
}
.process-steps__arrow-{{ sid }} svg path{
  fill: {{ section.settings.arrow_icon_color }};
}

/* mobile: stack steps */
@media (max-width: 900px){
  .process-steps__grid-{{ sid }}{
    grid-template-columns: 1fr;
  }
  .process-steps__step-{{ sid }}{
    min-height: auto;
    padding: 18px 18px;
    text-align: center;
  }
  .process-steps__step-{{ sid }}:not(:first-child){
    border-left: 0;
    border-top: 1px solid {{ section.settings.step_divider_color }};
  }

  /* arrows become chevrons between rows */
  .process-steps__arrow-{{ sid }}{
    left: 50% !important;
    top: auto;
    bottom: -{{ section.settings.arrow_size | divided_by: 2 }}px;
    transform: translate(-50%, 0);
  }
}

@media (max-width: 768px){
  .process-steps-{{ sid }}{
    padding-bottom: calc({{ section.settings.section_padding_bottom }}px - 70px);
  }
}
{% endstyle %}

<section class="process-steps process-steps-{{ sid }}">
  <!-- Background -->
  <div class="process-steps__bg-{{ sid }}">
    {% if section.settings.background_image != blank %}
      <img
        class="process-steps__bg-img-{{ sid }}"
        src="{{ section.settings.background_image | image_url: width: 2400 }}"
        alt="{{ section.settings.background_image.alt | escape }}"
        loading="lazy"
        width="2400"
        height="1200"
      >
    {% endif %}
    <div class="process-steps__overlay-{{ sid }}"></div>
  </div>

  <div class="page-width process-steps__wrap-{{ sid }}">
    <!-- Header -->
    <div class="process-steps__header-{{ sid }}">
      {% if section.settings.pretitle != blank %}
        <div class="section-header__pretitle">
          {% if section.settings.pretitle_icon != blank %}
            <img
              src="{{ section.settings.pretitle_icon | image_url: width: 48 }}"
              alt=""
              loading="lazy"
              width="30"
              height="30"
              class="section-header__pretitle-icon"
            >
          {% endif %}
          <span style="color: {{ section.settings.pretitle_color }}">{{ section.settings.pretitle }}</span>
        </div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="process-steps__heading-{{ sid }}">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="process-steps__text-{{ sid }}">{{ section.settings.text }}</div>
      {% endif %}
    </div>

    <!-- Steps -->
    {% if section.blocks.size > 0 %}
      <div class="process-steps__strip-{{ sid }}">
        <div class="process-steps__grid-{{ sid }}">
          {% for block in section.blocks %}
            <div class="process-steps__step-{{ sid }}" {{ block.shopify_attributes }}>
              <div class="process-steps__step-text-{{ sid }}">
                {{ block.settings.step_text }}
              </div>

              {%- comment -%}
                Arrow circles are rendered for every divider (between steps).
                Desktop: positioned on divider (left edge of each step except first).
                Mobile: positioned below each step except last.
              {%- endcomment -%}
              {% unless forloop.first %}
                <div
                  class="process-steps__arrow-{{ sid }}"
                  style="left: 0;"
                  aria-hidden="true"
                >
                  {% if section.settings.arrow_icon == 'chevron' %}
                    <svg viewBox="0 0 24 24" role="presentation" focusable="false" aria-hidden="true">
                      <path d="M9.29 6.71a1 1 0 0 0 0 1.41L13.17 12l-3.88 3.88a1 1 0 1 0 1.41 1.41l4.59-4.59a1 1 0 0 0 0-1.41L10.7 6.7a1 1 0 0 0-1.41.01z"></path>
                    </svg>
                  {% else %}
                    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M5 12H19M13 6L19 12L13 18"
                        fill="none"
                        stroke="{{ section.settings.arrow_icon_color }}"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"/>
                    </svg>
                  {% endif %}
                </div>
              {% endunless %}

              {% if forloop.last == false %}
                <div
                  class="process-steps__arrow-{{ sid }}"
                  style="left: 100%;"
                  aria-hidden="true"
                >
                  {% if section.settings.arrow_icon == 'chevron' %}
                    <svg viewBox="0 0 24 24" role="presentation" focusable="false" aria-hidden="true">
                      <path d="M9.29 6.71a1 1 0 0 0 0 1.41L13.17 12l-3.88 3.88a1 1 0 1 0 1.41 1.41l4.59-4.59a1 1 0 0 0 0-1.41L10.7 6.7a1 1 0 0 0-1.41.01z"></path>
                    </svg>
                  {% else %}
                    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M5 12H19M13 6L19 12L13 18"
                        fill="none"
                        stroke="{{ section.settings.arrow_icon_color }}"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"/>
                    </svg>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    {% if section.settings.note != blank %}
      <div class="process-steps__note-{{ sid }}">{{ section.settings.note }}</div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Process steps (arrows)",
  "class": "index-section",
  "settings": [
    { "type": "header", "content": "Background" },
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#0b6b3a" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 80 },

    { "type": "header", "content": "Header" },
    { "type": "text", "id": "pretitle", "label": "Pretitle", "default": "Order Process" },
    { "type": "image_picker", "id": "pretitle_icon", "label": "Pretitle icon" },
    {
      "type": "select",
      "id": "pretitle_color",
      "label": "Pre-title color",
      "default": "#fff",
      "options": [
        { "value": "#006d2a", "label": "Green" },
        { "value": "#fff", "label": "White" },
        { "value": "#F1D1A7", "label": "Golden" }
      ]
    },
    { "type": "text", "id": "heading", "label": "Heading", "default": "How Orders Work" },
    { "type": "richtext", "id": "text", "label": "Intro text", "default": "<p>Simple 4-step visual section:</p>" },

    { "type": "header", "content": "Steps" },
    { "type": "color", "id": "strip_bg", "label": "Strip background", "default": "#ffffff" },
    { "type": "range", "id": "strip_radius", "label": "Strip border radius", "min": 0, "max": 60, "step": 2, "unit": "px", "default": 18 },
    { "type": "range", "id": "strip_max_width", "label": "Strip max width", "min": 520, "max": 1400, "step": 20, "unit": "px", "default": 1200 },

    { "type": "color", "id": "step_divider_color", "label": "Step divider color", "default": "#e9e9e9" },
    { "type": "range", "id": "step_padding_y", "label": "Step padding Y", "min": 10, "max": 50, "step": 2, "unit": "px", "default": 26 },
    { "type": "range", "id": "step_padding_x", "label": "Step padding X", "min": 10, "max": 50, "step": 2, "unit": "px", "default": 18 },
    { "type": "range", "id": "step_min_height", "label": "Step min height", "min": 50, "max": 140, "step": 2, "unit": "px", "default": 86 },

    { "type": "range", "id": "step_text_size", "label": "Step text size", "min": 12, "max": 22, "step": 1, "unit": "px", "default": 16 },
    { "type": "color", "id": "step_text_color", "label": "Step text color", "default": "#1b1b1b" },

    { "type": "header", "content": "Arrows" },
    {
      "type": "select",
      "id": "arrow_icon",
      "label": "Arrow icon",
      "default": "chevron",
      "options": [
        { "value": "chevron", "label": "Chevron right" },
        { "value": "arrow", "label": "Arrow" }
      ]
    },
    { "type": "range", "id": "arrow_size", "label": "Arrow circle size", "min": 28, "max": 70, "step": 2, "unit": "px", "default": 44 },
    { "type": "color", "id": "arrow_bg", "label": "Arrow circle background", "default": "#1f7a3c" },
    { "type": "color", "id": "arrow_icon_color", "label": "Arrow icon color", "default": "#ffffff" },

    { "type": "header", "content": "Footer note" },
    { "type": "richtext", "id": "note", "label": "Note text", "default": "<p>This drastically reduces refunds and support tickets.</p>" },
    { "type": "range", "id": "note_gap", "label": "Gap above note", "min": 0, "max": 80, "step": 5, "unit": "px", "default": 25 },
    { "type": "range", "id": "note_max_width", "label": "Note max width", "min": 420, "max": 1100, "step": 20, "unit": "px", "default": 900 },
    { "type": "range", "id": "note_size", "label": "Note size", "min": 12, "max": 22, "step": 1, "unit": "px", "default": 16 },
    { "type": "color", "id": "note_color", "label": "Note color", "default": "#dfeee6" },

    { "type": "header", "content": "Layout" },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Section padding top",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Section padding bottom",
      "min": 0,
      "max": 240,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_margin_top",
      "label": "Section margin top",
      "min": -200,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "section_margin_bottom",
      "label": "Section margin bottom",
      "min": -200,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 0
    },
    { "type": "range", "id": "header_max_width", "label": "Header max width", "min": 420, "max": 1100, "step": 20, "unit": "px", "default": 900 },
    { "type": "range", "id": "header_gap", "label": "Gap under header", "min": 10, "max": 80, "step": 5, "unit": "px", "default": 40 },

    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 24, "max": 70, "step": 2, "unit": "px", "default": 54 },
    { "type": "range", "id": "body_size", "label": "Intro text size", "min": 12, "max": 22, "step": 1, "unit": "px", "default": 16 },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#dfeee6" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text", "id": "step_text", "label": "Step text", "default": "Order today" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Process steps (arrows)",
      "blocks": [
        { "type": "step" },
        { "type": "step", "settings": { "step_text": "Stock" } },
        { "type": "step", "settings": { "step_text": "Orders" } },
        { "type": "step", "settings": { "step_text": "Tracking" } }
      ]
    }
  ],
  "max_blocks": 6,
  "disabled_on": {
    "groups": ["custom.popups"]
  }
}
{% endschema %}