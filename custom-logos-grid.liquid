{% comment %}
  Custom Logo Grid
  - Desktop: CSS Grid auto-fit minmax
  - Mobile (option): 1 row horizontal swipe in flex
{% endcomment %}

<section
    class="logoGrid"
    data-mobile-swipe="{{ section.settings.mobile_swipe }}"
    data-auto-scroll="{{ section.settings.auto_scroll }}"
    data-direction="{{ section.settings.direction }}"
    style="
      --min-col: {{ section.settings.min_col }}px;
      --gap: {{ section.settings.gap }}px;
      --logo-max-height: {{ section.settings.max_height }}px;
      --scroll-speed: {{ section.settings.scroll_speed }}s;
    "
  >
    {% if section.settings.title != blank %}
      <h2 class="logoGrid__title">{{ section.settings.title }}</h2>
    {% endif %}
  
    <div class="logoGrid__marquee">
    <div class="logoGrid__container" role="list">
      {% assign logo_blocks = section.blocks %}
  {% if section.settings.auto_scroll %}
    {% assign logo_blocks = section.blocks | concat: section.blocks %}
  {% endif %}
  
  {% for block in logo_blocks %}
        {% assign img = block.settings.logo %}
        {% if img != blank %}
          <div class="logoGrid__item" role="listitem" {{ block.shopify_attributes }}>
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="logoGrid__link" aria-label="{{ block.settings.alt | escape }}">
            {% endif %}
  
            {{
              img
              | image_url: width: 600
              | image_tag:
                loading: "lazy",
                class: "logoGrid__img",
                widths: "160, 240, 320, 480, 600",
                alt: block.settings.alt
            }}
  
            {% if block.settings.link != blank %}
              </a>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
    </div>
  </section>
  
  <style>
  .logoGrid {
    padding: 16px 0;
  }
  
  .logoGrid__title {
    margin: 0 0 16px;
    font-size: 1.25rem;
    line-height: 1.2;
  }
  
  .logoGrid__container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(var(--min-col), 1fr));
    gap: var(--gap);
    align-items: center;
  }
  
  .logoGrid__item {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px;
  }
  
  .logoGrid__link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
  }
  
  .logoGrid__img {
    max-width: 100%;
    height: auto;
    max-height: var(--logo-max-height);
    object-fit: contain;
    display: block;
    opacity:.75
  }
  
  /* ===== MOBILE SWIPE VERSION ===== */
  @media (max-width: 870px) {
  
    .logoGrid[data-mobile-swipe="true"] .logoGrid__container {
      display: flex;
      flex-wrap: nowrap;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      gap: var(--gap);
      padding-bottom: 6px;
      scroll-snap-type: x mandatory;
    }
  
    .logoGrid[data-mobile-swipe="true"] .logoGrid__item {
      flex: 0 0 clamp(140px, 45vw, 180px);
      scroll-snap-align: start;
    }
  
    /* scrollbar */
    .logoGrid[data-mobile-swipe="true"] .logoGrid__container::-webkit-scrollbar {
      height: 6px;
    }
  }
  
  /* ============================= */
  /* AUTO SCROLL MARQUEE MODE */
  /* ============================= */
  
  .logoGrid[data-auto-scroll="true"] .logoGrid__marquee {
    overflow: hidden;
    position: relative;
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }
  
  .logoGrid[data-auto-scroll="true"] .logoGrid__container {
    display: flex;
    align-items: center;
    gap: calc(var(--gap) * 0.8);
    width: max-content;
    animation: logo-marquee linear infinite;
    animation-duration: var(--scroll-speed);
  }
  
  .logoGrid[data-auto-scroll="true"][data-direction="left"] .logoGrid__container {
    animation-name: logo-marquee-left;
  }
  
  .logoGrid[data-auto-scroll="true"][data-direction="right"] .logoGrid__container {
    animation-name: logo-marquee-right;
  }
  
  .logoGrid[data-auto-scroll="true"] .logoGrid__item {
    flex: 0 0 auto;
    padding: 0 12px;
  }
  .logoGrid__img {
    height: auto;
    max-height: var(--logo-max-height);
    width: auto;
    max-width: 160px;
    object-fit: contain;
  }
  
  /* Animations */
  
  @keyframes logo-marquee-left {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  
  @keyframes logo-marquee-right {
    from { transform: translateX(-50%); }
    to { transform: translateX(0); }
  }
  </style>
  
  {% schema %}
  {
    "name": "Custom Logo grid",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Titre",
        "default": "They trust us"
      },
      {
        "type": "checkbox",
        "id": "mobile_swipe",
        "label": "Swipe on mobile (1 row)",
        "default": true
      },
      {
        "type": "range",
        "id": "min_col",
        "label": "Min. Width Desktop (px)",
        "min": 120,
        "max": 240,
        "step": 10,
        "default": 160
      },
      {
        "type": "range",
        "id": "gap",
        "label": "Gap (px)",
        "min": 4,
        "max": 40,
        "step": 2,
        "default": 16
      },
      {
        "type": "range",
        "id": "max_height",
        "label": "Logo Max. Height (px)",
        "min": 20,
        "max": 120,
        "step": 5,
        "default": 50
      },
      {
    "type": "checkbox",
    "id": "auto_scroll",
    "label": "Activate automatic scrolling",
    "default": false
  },
  {
    "type": "select",
    "id": "direction",
    "label": "Scroll Direction",
    "default": "left",
    "options": [
      { "value": "left", "label": "To the left" },
      { "value": "right", "label": "To the right" }
    ]
  },
  {
    "type": "range",
    "id": "scroll_speed",
    "label": "Scroll Speed (in seconds)",
    "min": 10,
    "max": 60,
    "step": 5,
    "default": 30
  }
    ],
    "blocks": [
      {
        "type": "logo",
        "name": " Logo",
        "settings": [
          {
            "type": "image_picker",
            "id": "logo",
            "label": "Logo image"
          },
          {
            "type": "url",
            "id": "link",
            "label": "Link (optionnal)"
          },
          {
            "type": "text",
            "id": "alt",
            "label": "Alternative text",
            "default": "Logo"
          }
        ]
      }
    ],
    "max_blocks": 50,
    "presets": [
      {
        "name": " Custom Logo Grid",
        "blocks": [
          { "type": "logo" },
          { "type": "logo" },
          { "type": "logo" },
          { "type": "logo" }
        ]
      }
    ]
  }
  {% endschema %}